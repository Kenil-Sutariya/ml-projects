# ─────────────────────────────────────────────
# Real-Time Research Copilot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to git.
# ─────────────────────────────────────────────

# Ollama server address (default when running locally)
OLLAMA_BASE_URL=http://localhost:11434

# Chat model to use for answer synthesis.
# Run `ollama list` to see your installed models.
# Examples: llama3.2, gemma3, mistral, phi3
OLLAMA_CHAT_MODEL=llama3.2

# Embedding model for semantic search over private knowledge base.
# Install with: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# (Optional) Tavily API key for real-time web search.
# Leave blank to skip web search — the app will still work fine.
# Get a free key at: https://tavily.com
TAVILY_API_KEY=

# Path where FAISS vector index will be saved (relative to project root)
VECTORSTORE_PATH=app/data/vectorstore

# FastAPI backend URL (used by the Streamlit frontend)
API_BASE_URL=http://localhost:8000
