# Universal ML Monitoring Platform — environment variables
# Copy this file to `.env` and fill in only the providers you want to use.
# `.env` is gitignored; keys never leave your machine.
#
# Multiple providers can coexist — the AI Insights page will let you pick one.

# --- Local Ollama (optional override; defaults to http://localhost:11434) ---
# OLLAMA_BASE_URL=http://localhost:11434
# Default request timeout in seconds (default: 180). Bump for large/slow models.
# OLLAMA_TIMEOUT=600

# --- Cloud LLMs (all OpenAI-compatible chat-completion endpoints) ---

# OpenAI
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Groq (very fast, free tier available)
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# OpenRouter (gateway to many model providers)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Gemini (via OpenAI-compatible endpoint)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Custom OpenAI-compatible endpoint (anything else)
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_DEFAULT_MODEL=
